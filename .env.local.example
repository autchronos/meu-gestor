# ---------- Desenvolvimento (Supabase local) ----------
# Rode `npm run db:start` — ele imprime estes valores.
# A anon key local e a chave padrao publica do Supabase: a mesma em toda maquina.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=cole-a-anon-key-que-o-db-start-imprimiu

# ---------- Producao (Supabase na nuvem) ----------
# Pegar em: Supabase > Project Settings > API
# VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# VITE_SUPABASE_ANON_KEY=sua-chave-anon

# A anon key e PUBLICA por desenho — ela vai para o bundle do navegador. Quem
# protege o dado e a RLS, nao a chave.
#
# A SERVICE_ROLE key NUNCA entra aqui, nem em nenhuma variavel VITE_*: ela IGNORA
# a RLS. Ela so existe do lado do servidor (Edge Function), lida de segredo.
